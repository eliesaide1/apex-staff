{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "preserveSymlinks": true,
    "types": ["jest", "node"],
    "paths": {
      "@apex/shared": ["./node_modules/@apex/shared/src/index.ts"],
      "@apex/shared/*": ["./node_modules/@apex/shared/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "node_modules/@apex/shared/src/**/*.ts",
    "node_modules/@apex/shared/src/**/*.tsx"
  ],
  "exclude": ["**/Pods/**"]
}
